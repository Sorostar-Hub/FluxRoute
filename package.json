{
  "name": "fluxroute",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky install",
    "postinstall": "husky install",
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "test:contracts": "cargo test --manifest-path contracts/Cargo.toml",
    "test:integration": "jest --config tests/jest.integration.config.ts",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx && turbo lint",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix && turbo lint -- --fix",
    "format": "prettier --write . && cargo fmt",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit -p tsconfig.base.json",
    "dev:solver": "turbo dev --filter=solver",
    "dev:indexer": "turbo dev --filter=indexer",
    "dev:frontend": "turbo dev --filter=frontend"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "@playwright/test": "^1.44.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
